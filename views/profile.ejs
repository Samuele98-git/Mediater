<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Account - <%= APP_NAME %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/netflix.css">
    <style>
        .account-wrap { max-width: 900px; margin: 110px auto 80px; padding: 0 40px; }
        .account-wrap h1 { font-size: 2.6rem; font-weight: 300; margin: 0 0 12px; }
        .account-wrap .sub { color: #888; border-bottom: 1px solid #333; padding-bottom: 20px; margin-bottom: 30px; }
        .profile-grid {
            display: grid; grid-template-columns: 200px 1fr;
            gap: 30px; align-items: flex-start;
            padding: 28px 0; border-bottom: 1px solid #333;
        }
        .avatar-block { display: flex; flex-direction: column; align-items: center; gap: 12px; }
        .avatar-box {
            position: relative; width: 160px; height: 160px;
            border-radius: 8px; overflow: hidden; cursor: pointer;
            background: #333; border: 3px solid transparent;
            transition: 0.2s ease;
        }
        .avatar-box:hover { border-color: white; }
        .avatar-box img { width: 100%; height: 100%; object-fit: cover; display: block; }
        .avatar-box input[type="file"] { position: absolute; inset: 0; opacity: 0; cursor: pointer; }
        .avatar-box .overlay {
            position: absolute; inset: 0; background: rgba(0,0,0,0.55);
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            color: white; opacity: 0; transition: opacity 0.2s ease;
            font-size: 14px; gap: 6px;
        }
        .avatar-box:hover .overlay { opacity: 1; }
        .avatar-box .overlay i { font-size: 28px; }
        .avatar-meta { text-align: center; }
        .avatar-meta .name { font-size: 1.2rem; font-weight: 600; margin-bottom: 4px; }
        .avatar-meta .role { font-size: 12px; color: #888; text-transform: uppercase; letter-spacing: 1px; }

        .form-block label { display: block; color: #b3b3b3; font-size: 13px; margin-bottom: 6px; font-weight: 600; }
        .form-block .field { margin-bottom: 18px; }
        .form-block input[type="text"], .form-block input[type="password"] {
            width: 100%; padding: 12px 14px;
            background: #333; border: 1px solid #404040; color: white;
            border-radius: 4px; font-size: 15px; outline: none;
            transition: border-color 0.2s ease;
        }
        .form-block input:focus { border-color: #888; background: #404040; }
        .form-block input::placeholder { color: #888; }
        .alert {
            padding: 10px 14px; border-radius: 4px; margin-bottom: 18px; font-size: 14px;
            display: flex; align-items: center; gap: 8px;
        }
        .alert-ok { background: rgba(70, 211, 105, 0.15); color: #46d369; border: 1px solid rgba(70, 211, 105, 0.35); }
        .alert-err { background: rgba(229, 9, 20, 0.15); color: var(--nf-red); border: 1px solid rgba(229, 9, 20, 0.35); }
        .sso-info {
            background: rgba(0, 113, 235, 0.15); border: 1px solid rgba(0, 113, 235, 0.4);
            color: #4ea8ff; padding: 12px 14px; border-radius: 4px;
            margin-bottom: 18px; font-size: 13px; line-height: 1.45;
        }
        .actions-row { display: flex; gap: 12px; margin-top: 18px; align-items: center; }
        .actions-row .nf-btn { padding: 11px 26px; }
        .actions-row .danger { color: #ff5b5b; }

        .file-hint { font-size: 12px; color: #888; }

        @media (max-width: 700px) {
            .account-wrap { margin: 90px auto 60px; padding: 0 20px; }
            .profile-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <%- include('partials/nav') %>

    <main class="account-wrap">
        <h1>Account</h1>
        <div class="sub">Member since <%= new Date(user.created_at).toLocaleDateString() %></div>

        <% const params = new URLSearchParams(typeof query !== 'undefined' ? query : ''); %>

        <form class="profile-grid" action="/profile/update" method="POST" enctype="multipart/form-data">
            <div class="avatar-block">
                <div class="avatar-box">
                    <img id="avatarPreview" src="<%= user.avatar || ('https://ui-avatars.com/api/?background=E50914&color=fff&size=160&name=' + encodeURIComponent(user.username)) %>" alt="">
                    <div class="overlay"><i class="fas fa-pencil-alt"></i> Change Avatar</div>
                    <input type="file" name="avatar" accept="image/*" onchange="previewAvatar(this)">
                </div>
                <div class="avatar-meta">
                    <div class="name"><%= user.username %></div>
                    <div class="role"><%= user.role %></div>
                </div>
            </div>

            <div class="form-block">
                <% if (locals.successMsg) { %>
                    <div class="alert alert-ok"><i class="fas fa-check-circle"></i> Profile updated</div>
                <% } %>
                <% if (locals.errorMsg) { %>
                    <div class="alert alert-err"><i class="fas fa-exclamation-circle"></i> <%= errorMsg %></div>
                <% } %>

                <% if (user.auth_provider === 'oidc') { %>
                    <div class="sso-info">
                        <i class="fas fa-shield-halved"></i> <strong>SSO Account</strong> — Username and password are managed by your identity provider. You can still change your avatar here.
                    </div>
                <% } %>

                <% if (user.auth_provider === 'local') { %>
                    <div class="field">
                        <label>Username</label>
                        <input type="text" name="username" value="<%= user.username %>" required>
                    </div>
                    <div class="field">
                        <label>New Password</label>
                        <input type="password" name="newPassword" placeholder="Leave blank to keep current password" autocomplete="new-password">
                    </div>
                <% } %>

                <div class="actions-row">
                    <button type="submit" class="nf-btn nf-btn-play"><i class="fas fa-save"></i> Save</button>
                    <a href="/" class="nf-btn nf-btn-info"><i class="fas fa-arrow-left"></i> Back to Home</a>
                    <a href="/logout" class="danger" style="margin-left:auto; font-size:14px;">
                        <i class="fas fa-sign-out-alt"></i> Sign out of all devices
                    </a>
                </div>
            </div>
        </form>
    </main>

    <script>
        function previewAvatar(input) {
            if (input.files && input.files[0]) {
                const r = new FileReader();
                r.onload = e => { document.getElementById('avatarPreview').src = e.target.result; };
                r.readAsDataURL(input.files[0]);
            }
        }
    </script>
</body>
</html>
