<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title><%= APP_NAME %> — <%= t('nav.home') %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/netflix.css">
</head>
<body>
    <%- include('partials/nav', { pageType }) %>

    <% if (hero) { %>
        <section class="nf-hero" style="background-image:url('<%= hero.backdrop || hero.thumbnail %>')">
            <div class="nf-hero-content">
                <% if (hero.logoUrl) { %>
                    <img src="<%= hero.logoUrl %>" alt="<%= hero.title %>" class="nf-hero-logo">
                <% } else { %>
                    <h1 class="nf-hero-title"><%= hero.title %></h1>
                <% } %>
                <div class="nf-hero-meta">
                    <span class="match"><%= t('home.match') %></span>
                    <% if (hero.releaseYear) { %><span><%= hero.releaseYear %></span><% } %>
                    <% if (hero.maturity) { %><span class="badge"><%= hero.maturity %></span><% } %>
                    <% if (hero.duration) { %>
                        <span><%= Math.floor(hero.duration / 60) %>h <%= hero.duration % 60 %>m</span>
                    <% } %>
                </div>
                <% if (hero.description) { %>
                    <p class="nf-hero-desc"><%= hero.description %></p>
                <% } %>
                <div class="nf-hero-actions">
                    <a href="/watch/<%= hero.id %>" class="nf-btn nf-btn-play"><i class="fas fa-play"></i> <%= t('home.play') %></a>
                    <button class="nf-btn nf-btn-info" onclick="window.__nfOpenModal(<%= hero.id %>)">
                        <i class="fas fa-info-circle"></i> <%= t('home.more_info') %>
                    </button>
                </div>
            </div>
        </section>
    <% } else { %>
        <section class="nf-hero nf-hero-empty">
            <div style="margin-top: 80px;">
                <h2 style="text-align:center; color:#888;"><%= t('home.empty_title') %></h2>
                <% if (user && user.role === 'admin') { %>
                    <p style="text-align:center; margin-top:14px;"><a href="/admin" class="nf-btn nf-btn-play"><i class="fas fa-plus"></i> <%= t('home.add_content') %></a></p>
                <% } %>
            </div>
        </section>
    <% } %>

    <div class="nf-rows <%= hero ? '' : 'no-hero' %>">

        <% if (continueWatching && continueWatching.length > 0) { %>
            <div class="nf-row">
                <h2 class="nf-row-title"><%= t('home.continue_watching') %></h2>
                <div class="nf-slider-wrap">
                    <button class="nf-arrow left" aria-label="Scroll left"><i class="fas fa-chevron-left"></i></button>
                    <div class="nf-slider">
                        <% continueWatching.forEach(m => {
                             const pct = m._progress && m._progress.duration > 0 ? Math.min(100, (m._progress.position / m._progress.duration) * 100) : 0;
                        %>
                            <a class="nf-card" href="/watch/<%= m._resumeId %>">
                                <% if (m.thumbnail || m.backdrop) { %>
                                    <img src="<%= m.backdrop || m.thumbnail %>" loading="lazy" alt="<%= m.title %>">
                                <% } else { %>
                                    <div class="placeholder"><i class="fas fa-film"></i></div>
                                <% } %>
                                <div class="nf-card-progress"><span style="width: <%= pct %>%"></span></div>
                                <div class="nf-card-title-overlay"><%= m.title %></div>
                            </a>
                        <% }) %>
                    </div>
                    <button class="nf-arrow right" aria-label="Scroll right"><i class="fas fa-chevron-right"></i></button>
                </div>
            </div>
        <% } %>

        <% if (trending && trending.length > 0) { %>
            <div class="nf-row">
                <h2 class="nf-row-title"><%= t('home.trending_now') %></h2>
                <div class="nf-slider-wrap">
                    <button class="nf-arrow left"><i class="fas fa-chevron-left"></i></button>
                    <div class="nf-slider">
                        <% trending.forEach(m => { %>
                            <div class="nf-card" data-id="<%= m.id %>">
                                <% if (m.thumbnail || m.backdrop) { %>
                                    <img src="<%= m.backdrop || m.thumbnail %>" loading="lazy" alt="<%= m.title %>">
                                <% } else { %>
                                    <div class="placeholder"><i class="fas fa-film"></i></div>
                                <% } %>
                                <div class="nf-card-title-overlay"><%= m.title %></div>
                            </div>
                        <% }) %>
                    </div>
                    <button class="nf-arrow right"><i class="fas fa-chevron-right"></i></button>
                </div>
            </div>
        <% } %>

        <% if (myListItems && myListItems.length > 0) { %>
            <div class="nf-row">
                <h2 class="nf-row-title"><%= t('nav.my_list') %></h2>
                <div class="nf-slider-wrap">
                    <button class="nf-arrow left"><i class="fas fa-chevron-left"></i></button>
                    <div class="nf-slider">
                        <% myListItems.forEach(m => { %>
                            <div class="nf-card" data-id="<%= m.id %>">
                                <% if (m.thumbnail || m.backdrop) { %>
                                    <img src="<%= m.backdrop || m.thumbnail %>" loading="lazy" alt="<%= m.title %>">
                                <% } else { %>
                                    <div class="placeholder"><i class="fas fa-film"></i></div>
                                <% } %>
                                <div class="nf-card-title-overlay"><%= m.title %></div>
                            </div>
                        <% }) %>
                    </div>
                    <button class="nf-arrow right"><i class="fas fa-chevron-right"></i></button>
                </div>
            </div>
        <% } %>

        <% Object.keys(rows).forEach(cat => { %>
            <div class="nf-row">
                <h2 class="nf-row-title"><%= cat %></h2>
                <div class="nf-slider-wrap">
                    <button class="nf-arrow left"><i class="fas fa-chevron-left"></i></button>
                    <div class="nf-slider">
                        <% rows[cat].forEach(m => { %>
                            <div class="nf-card" data-id="<%= m.id %>">
                                <% if (m.thumbnail || m.backdrop) { %>
                                    <img src="<%= m.backdrop || m.thumbnail %>" loading="lazy" alt="<%= m.title %>">
                                <% } else { %>
                                    <div class="placeholder"><i class="fas fa-film"></i></div>
                                <% } %>
                                <div class="nf-card-title-overlay"><%= m.title %></div>
                            </div>
                        <% }) %>
                    </div>
                    <button class="nf-arrow right"><i class="fas fa-chevron-right"></i></button>
                </div>
            </div>
        <% }) %>

    </div>

    <footer style="text-align:center; color:#777; padding: 30px 60px; font-size: 13px;">
        <%= t('home.footer', { year: new Date().getFullYear(), app: APP_NAME }) %>
    </footer>

    <%- include('partials/modal') %>
    <%- include('partials/i18n') %>
    <script src="/js/netflix.js"></script>
</body>
</html>
