# ==============================================================
# Mediater — environment configuration
# Copy this file to `.env` and edit the values before starting.
# ==============================================================

# Runtime mode: "development" or "production"
NODE_ENV=production

# HTTP port to listen on
PORT=3000

# Bind address. Use 0.0.0.0 to accept connections from the network
# (required inside Docker / on a server). Use 127.0.0.1 to restrict
# to localhost in development.
HOST=0.0.0.0

# REQUIRED in production. Long random string used to sign session
# cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# How many days a "remember me" session should last.
SESSION_TTL_DAYS=30

# Set to "true" when serving Mediater behind HTTPS (e.g. via Nginx).
# This makes session cookies "Secure" so they're only sent over TLS.
COOKIE_SECURE=false

# Number of trusted proxy hops, or "true" if Mediater sits behind a
# single reverse proxy (Nginx, Traefik, Caddy, Cloudflare…).
# Leave blank if direct-facing.
TRUST_PROXY=1

# Bootstrap admin credentials (only used the first time the DB is
# empty). CHANGE THE PASSWORD before deploying to production.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Prisma database URL (SQLite by default). For Docker, point this at
# a volume-mounted folder so the data survives container restarts.
DATABASE_URL=file:./dev.db

# Optional override paths (handy in Docker).
# UPLOAD_DIR=/data/uploads
# SESSION_DIR=/data/sessions
